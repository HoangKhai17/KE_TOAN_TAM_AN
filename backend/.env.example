# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://ktta_user:your_password@postgres:5432/ktta_db
POSTGRES_DB=ktta_db
POSTGRES_USER=ktta_user
POSTGRES_PASSWORD=your_strong_password_here

# Redis
REDIS_URL=redis://:your_redis_password@redis:6379
REDIS_PASSWORD=your_redis_password_here

# JWT
JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=generate_with_openssl_rand_hex_64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for company credentials)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=64_hex_chars_here

# Frontend URL (for CORS) — comma-separated list of allowed origins.
# Dev: include BOTH Vite dev server AND Docker/nginx port so socket works in both setups.
# Docker dev (docker compose up): browser opens localhost:8080 — must be in this list.
# Vite dev (npm run dev): browser opens localhost:5173 — must be in this list.
# Production: set to your actual domain, e.g. https://myapp.com
FRONTEND_URL=http://localhost:5173,http://localhost:8080

# Microsoft Graph API (OneDrive Personal — Delegated flow)
# MICROSOFT_TENANT_ID không cần thiết với Personal account
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:5173/settings
# MICROSOFT_DRIVE_ID tự động lưu vào DB khi kết nối, không cần điền thủ công

# Email (SMTP — Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ketoan-taman.vn

# Sentry (optional, leave empty in dev)
SENTRY_DSN=

# Logging
LOG_LEVEL=debug
