{
  "name": "ktta-backend",
  "version": "1.0.0",
  "description": "Ke Toan Tam An — Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:watch": "jest --watch",
    "migrate:up": "node src/db/migrate.js up",
    "migrate:down": "node src/db/migrate.js down",
    "migrate:status": "node src/db/migrate.js status",
    "seed": "node src/db/seed.js",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "express": "4.19.2",
    "pg": "8.11.5",
    "ioredis": "5.3.2",
    "bcrypt": "5.1.1",
    "jsonwebtoken": "9.0.2",
    "uuid": "9.0.1",
    "zod": "3.23.8",
    "helmet": "7.1.0",
    "cors": "2.8.5",
    "express-rate-limit": "7.3.1",
    "morgan": "1.10.0",
    "winston": "3.13.0",
    "winston-daily-rotate-file": "5.0.0",
    "node-cron": "3.0.3",
    "axios": "1.7.2",
    "dotenv": "16.4.5",
    "exceljs": "4.4.0",
    "nodemailer": "6.9.14",
    "date-fns": "3.6.0",
    "multer": "1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "3.1.4",
    "jest": "29.7.0",
    "supertest": "7.0.0",
    "@faker-js/faker": "8.4.1",
    "eslint": "8.57.0",
    "prettier": "3.3.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ]
  }
}
